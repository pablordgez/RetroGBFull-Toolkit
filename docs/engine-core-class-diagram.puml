@startuml RetroGBFull_Engine_Core_Class_Diagram
title RetroGBFull Toolkit - Engine Core\nPseudo object oriented class diagram

skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
hide circle
hide empty members

legend right
  The engine is written in C, so this diagram treats structs as classes,
  module globals such as THIS_ACTOR as implicit "this" pointers,
  and FAR_PTR function arrays as vtables/registries.
endlegend

package "Runtime" {
  class Engine <<application>> {
    +main()
    -init_systems()
  }

  class GameManager <<singleton_context>> {
    -current_scene : Scene*
    -pending_scene : Scene*
    +update_game()
    +set_scene(scene : Scene*)
    +set_scene_deferred(scene : Scene*)
  }

  class ScriptEnvironment <<facade>> {
    +actor_api()
    +scene_api()
    +collision_api()
    +asset_registries()
    +text_api()
    +interrupt_api()
    +save_data_api()
  }
}

package "Scenes" {
  class Scene <<base_entity>> {
    -actors : Actor**
    -num_actors : uint8_t
    -type : SceneType
    -map : Map*
    -window : Map*
    +init_scene(scene : Scene*)
    +add_actor(actor : Actor*)
    +remove_actor(actor : Actor*)
    +update_actors()
    +draw_actors()
    +get_actors_by_tag(tag : Tags, result : Actor*[])
    +cleanup_scene(scene : Scene*)
    +set_scene_map(map : Map*)
    +set_scene_window(map : Map*)
  }

  class SampleScene <<generated_scene>> {
    -base : Scene
    +SINIT()
    +SUPDATE()
  }

  class SceneRegistry <<registry_vtable>> {
    -scene_init_state_functions : FAR_PTR[NUM_SCENES]
    -scene_update_functions : FAR_PTR[NUM_SCENES]
    +init_scene_functions()
  }

  enum SceneType {
    _SampleScene
    NUM_SCENES
  }
}

package "Actors" {
  class Actor <<entity>> {
    -type : ActorType
    -tags : Tags[5]
    -current_animation : Animation*
    -animation_state : AnimationState*
    -x : uint16_t
    -y : uint16_t
    -collider : Collider*
    -child : Actor*
    -sibling : Actor*
    -parent : Actor*
    -physics_mode : PhysicsMode
    -followed : uint8_t
    +init_actor(actor : Actor*)
    +set_tag(tag : Tags, index : uint8_t)
    +set_actor_animation(animation : Animation*)
    +set_animation_context()
    +draw()
    +move_actor(dx : int16_t, dy : int16_t)
    +set_actor_position(x : uint16_t, y : uint16_t)
    +balanced_physics(dx : int16_t, dy : int16_t)
    +attach_child(child : Actor*)
    +detach_child(child : Actor*)
    +set_collider(collider : Collider*)
    +destroy_actor(actor : Actor*)
  }

  class ActorRegistry <<registry_vtable>> {
    -actor_update_functions : FAR_PTR[NUM_ACTORS]
    -actor_init_functions : FAR_PTR[NUM_ACTORS]
    +init_actor_functions()
  }

  enum ActorType {
    NUM_ACTORS = 1
  }

  enum Tags {
    TAG_NONE
  }

  enum PhysicsMode {
    HIGH_PERF
    BALANCED
    HIGH_FIDELITY
  }
}

package "Collisions" {
  class Collider <<component>> {
    -x : uint16_t
    -y : uint16_t
    -type : uint8_t
    -id : uint8_t
    -is_blocking : uint8_t
    -width : uint16_t
    -height : uint16_t
    -tags : Tags[5]
    -on_collision : CollisionCallback[MAX_COLLISION_CALLBACKS]
    -on_collision_exit : CollisionCallback[MAX_COLLISION_CALLBACKS]
    -num_collision_callbacks : uint8_t
    -num_collision_exit_callbacks : uint8_t
    +check_collision() : uint8_t
  }

  class BoxCollider <<specialized_collider>> {
    -base : Collider
  }

  class CollisionManager <<singleton_service>> {
    -active_colliders : Collider*[MAX_ACTIVE_COLLIDERS]
    -num_active_colliders : uint8_t
    -collision_state : uint8_t[MAX_COLLISION_STATE_BYTES]
    +enable_collider(collider : Collider*)
    +disable_collider(collider : Collider*)
    +set_collision_callback(collider : Collider*, callback : CollisionCallback)
    +set_collision_exit_callback(collider : Collider*, callback : CollisionCallback)
    +check_collisions(out : Collider*[])
    +check_collisions_with_tags(out : Collider*[], tag : Tags)
    +check_blocking_collisions(out : Collider*[])
    +check_blocking_collisions_with_tags(out : Collider*[], tag : Tags)
    +run_collision_callbacks()
  }

  enum ColliderType {
    BOX_COLLIDER
    NUM_COLLIDER
  }

  interface CollisionCallback <<function_pointer>> {
    +invoke()
  }
}

package "Visual Assets" {
  class Animation <<asset>> {
    -number_of_frames : uint8_t
    -width : uint8_t
    -height : uint8_t
    -frame_duration : uint8_t
    -animation_id : uint8_t
    -metasprite : metasprite_t*
  }

  class AnimationState <<runtime_state>> {
    -speed_modifier : uint8_t
    -current_frame : uint8_t
    -sprite_slot : uint8_t
    -props : uint8_t
    -time_since_last_frame : uint8_t
  }

  class AnimationSystem <<singleton_service>> {
    +init_animation_system()
    +init_animation_state(state : AnimationState*)
    +load_animation(x : uint8_t, y : uint8_t) : uint8_t
    +unload_animation()
    +set_animation_props(props : uint8_t, x : uint8_t, y : uint8_t)
    +move_animation(x : uint8_t, y : uint8_t)
    +update_animation(x : uint8_t, y : uint8_t)
    +hide_animation()
  }

  class AnimationRegistry <<asset_registry>> {
    -animations : Animation*[NUMBER_OF_ANIMATIONS]
    -animation_data : AssetEntry[NUMBER_OF_ANIMATIONS]
    -animation_tiles : uint8_t[NUMBER_OF_ANIMATIONS]
    -animation_loaded : uint8_t[NUMBER_OF_ANIMATIONS]
  }

  class Map <<asset>> {
    -id : uint8_t
    -width : uint16_t
    -height : uint16_t
    -tileset : uint8_t*
    -num_tiles : uint8_t
    -first_tile : uint8_t
    -window_top_end : uint8_t
    -window_bottom_start : uint8_t
    +load_map(window : uint8_t)
    +unload_map()
    +load_map_section(x : uint8_t, y : uint8_t, width : uint8_t, height : uint8_t, window : uint8_t)
    +register_changed_map_tile(x : uint8_t, y : uint8_t, tile : uint8_t) : uint8_t
    +change_changed_map_tile(x : uint8_t, y : uint8_t, tile : uint8_t) : uint8_t
    +delete_changed_map_tile(x : uint8_t, y : uint8_t) : uint8_t
    +clear_changed_map_tiles()
  }

  class MapSystem <<singleton_service>> {
    +init_map_system()
  }

  class MapRegistry <<asset_registry>> {
    -maps : Map*[NUMBER_OF_MAPS]
    -map_data : AssetEntry[NUMBER_OF_MAPS]
  }

  class AssetEntry <<banked_asset>> {
    -bank : uint8_t
    -data : uint8_t*
  }

  class SpaceManager <<allocator>> {
    -spaces : uint8_t*
    -total_spaces : uint8_t
    +init_space_manager(manager : SpaceManager*, num_spaces : uint8_t)
    +register_space(manager : SpaceManager*, size : uint8_t) : uint8_t
    +remove_spaces(manager : SpaceManager*, slot : uint8_t, size : uint8_t)
  }

  class Camera <<singleton_service>> {
    -camera_x : uint16_t
    -camera_y : uint16_t
    -deadzone_left : uint8_t
    -deadzone_right : uint8_t
    -deadzone_top : uint8_t
    -deadzone_bottom : uint8_t
    +update_camera(worldx : uint16_t, worldy : uint16_t)
  }
}

package "Audio" {
  class MusicPlayer <<singleton_service>> {
    -current_song : Song*
    +play_song(song : Song*, loop : uint8_t)
    +play_music_step()
    +music_update()
    +stop_music()
  }

  class Song <<asset>> {
    -bank : uint8_t
    -speed : uint8_t
    -sequence_length : uint8_t
    -instruments : Instrument*
    -ch1_seq : Pattern**
    -ch2_seq : Pattern**
    -ch4_seq : Pattern**
  }

  class Pattern <<value_object>> {
    -steps : Step[PATTERN_LENGTH]
  }

  class Step <<value_object>> {
    -note_index : uint8_t
    -instrument : uint8_t
  }

  class Instrument <<value_object>> {
    -reg1 : uint8_t
    -reg2 : uint8_t
    -reg3 : uint8_t
  }

  class SongRegistry <<asset_registry>> {
    -songs : Song*[NUMBER_OF_SONGS]
  }
}

package "Text and Window" {
  class TextSystem <<singleton_service>> {
    +init_text_system()
    +init_text_handle(handle : TextHandle*)
    +create_text_handle() : TextHandle*
    +destroy_text_handle(handle : TextHandle*)
    +measure_text_banked(x : uint8_t, y : uint8_t, text : char*, out : TextMetrics*, bank : uint8_t)
    +draw_text_banked(handle : TextHandle*, layer : TextLayer, x : uint8_t, y : uint8_t, text : char*, bank : uint8_t)
    +remove_text(handle : TextHandle*)
    +move_text(handle : TextHandle*, x : uint8_t, y : uint8_t)
    +update_text_banked(handle : TextHandle*, text : char*, bank : uint8_t)
    +clear_all_text()
    +text_set_font(font_index : uint8_t)
    +text_set_colors(fg : uint8_t, bg : uint8_t)
  }

  class TextHandle <<runtime_handle>> {
    -active : uint8_t
    -layer : uint8_t
    -x : uint8_t
    -y : uint8_t
    -tilemap_y : uint8_t
    -width : uint8_t
    -height : uint8_t
    -saved_tiles_valid : uint8_t
    -first_tile : uint8_t
    -tile_count : uint8_t
    -text_bank : uint8_t
    -saved_tiles : uint8_t*
    -text : char*
  }

  class TextMetrics <<value_object>> {
    -tile_count : uint8_t
    -x : uint8_t
    -y : uint8_t
    -width : uint8_t
    -height : uint8_t
  }

  enum TextLayer {
    TEXT_LAYER_BACKGROUND
    TEXT_LAYER_WINDOW
  }

  class WindowVisibility <<singleton_service>> {
    +init_window_visibility_system()
    +window_visibility_clear_owner(owner : uint8_t)
    +window_visibility_add_band(owner : uint8_t, start_ly : uint8_t, end_ly : uint8_t) : uint8_t
    +window_visibility_apply() : uint8_t
    +window_visibility_get_tile_row_for_screen_y(screen_ly : uint8_t) : uint8_t
  }
}

package "Interrupts and Link" {
  class InterruptManager <<singleton_service>> {
    +init_interrupt_manager()
    +add_vblank_interrupt_callback(callback : InterruptCallback) : uint8_t
    +remove_vblank_interrupt_callback(callback : InterruptCallback) : uint8_t
    +clear_vblank_interrupt_callbacks()
    +set_vblank_interrupt_callback(callback : InterruptCallback)
    +add_serial_interrupt_callback(callback : InterruptCallback) : uint8_t
    +remove_serial_interrupt_callback(callback : InterruptCallback) : uint8_t
    +clear_serial_interrupt_callbacks()
    +set_serial_interrupt_callback(callback : InterruptCallback)
    +add_timer_interrupt_callback(callback : InterruptCallback) : uint8_t
    +remove_timer_interrupt_callback(callback : InterruptCallback) : uint8_t
    +clear_timer_interrupt_callbacks()
    +set_timer_interrupt_callback(clock_select : uint8_t, modulo : uint8_t, callback : InterruptCallback)
    +disable_timer_interrupt()
    +clear_lcd_scanline_interrupts()
    +add_lcd_scanline_interrupt(ly : uint8_t, callback : InterruptCallback) : uint8_t
    +remove_lcd_scanline_interrupt(ly : uint8_t, callback : InterruptCallback) : uint8_t
    +clear_lcd_scanline_interrupts_for_callback(callback : InterruptCallback)
  }

  class LcdScanlineInterrupt <<value_object>> {
    -ly : uint8_t
    -callback : InterruptCallback
  }

  interface InterruptCallback <<function_pointer>> {
    +invoke()
  }

  class TimerInterrupt <<adapter>> {
    +init_timer_interrupt(frequency_hz : uint16_t, callback : InterruptCallback)
    +stop_timer_interrupt()
  }

  class SerialLink <<singleton_service>> {
    +init_serial_link(is_master : uint8_t)
    +shutdown_serial_link()
    +send_serial_link_byte(data : uint8_t)
    +serial_link_ready() : uint8_t
    +serial_link_has_error() : uint8_t
    +get_serial_link_byte() : uint8_t
  }
}

package "Persistence" {
  class SaveData <<data_object>> {
    -signature : uint8_t[4]
    +init_save_data()
    +load_save_data()
    +save_save_data()
  }
}

Engine --> GameManager : owns stack instance
Engine ..> ActorRegistry : initializes
Engine ..> SceneRegistry : initializes
Engine ..> AnimationSystem : initializes
Engine ..> MapSystem : initializes
Engine ..> InterruptManager : initializes
Engine ..> WindowVisibility : initializes
Engine ..> TextSystem : initializes
Engine ..> SaveData : loads
Engine ..> SampleScene : creates starting scene

ScriptEnvironment ..> Actor
ScriptEnvironment ..> Scene
ScriptEnvironment ..> CollisionManager
ScriptEnvironment ..> AnimationRegistry
ScriptEnvironment ..> MapRegistry
ScriptEnvironment ..> SongRegistry
ScriptEnvironment ..> TextSystem
ScriptEnvironment ..> InterruptManager
ScriptEnvironment ..> SaveData

GameManager o-- "0..1 current" Scene
GameManager o-- "0..1 pending" Scene
GameManager ..> SceneRegistry : dispatch init/update
GameManager ..> CollisionManager : optional per-frame callbacks

SampleScene --|> Scene : embeds base
Scene --> SceneType
Scene *-- "0..*" Actor : owns
Scene o-- "0..1 world" Map
Scene o-- "0..1 window" Map
Scene ..> SceneRegistry : type selects callbacks
Scene ..> TextSystem : clears text on cleanup
Scene ..> WindowVisibility : configures window split
Scene ..> Camera : followed actor updates camera
SceneRegistry --> SceneType

Actor --> ActorType
Actor --> Tags
Actor --> PhysicsMode
Actor o-- "0..1" Animation
Actor *-- "0..1" AnimationState
Actor *-- "0..1" Collider
Actor --> "0..1 child" Actor
Actor --> "0..1 sibling" Actor
Actor --> "0..1 parent" Actor
Actor ..> ActorRegistry : type selects callbacks
Actor ..> AnimationSystem : loads/draws/hides
Actor ..> CollisionManager : movement queries
Actor ..> Camera : draw culling offsets
ActorRegistry --> ActorType

BoxCollider --|> Collider : embeds base
Collider --> ColliderType
Collider --> Tags
Collider o-- "0..*" CollisionCallback : on_collision
Collider o-- "0..*" CollisionCallback : on_collision_exit
CollisionManager o-- "0..20 active" Collider
CollisionManager ..> CollisionCallback : dispatches

AnimationSystem --> Animation
AnimationSystem --> AnimationState
AnimationSystem ..> SpaceManager : VRAM slot allocation
AnimationRegistry o-- "0..*" Animation
AnimationRegistry o-- "0..*" AssetEntry
MapSystem --> Map
MapSystem *-- SpaceManager : map_space_manager
MapRegistry o-- "0..*" Map
MapRegistry o-- "0..*" AssetEntry
Map ..> SpaceManager : tile space allocation

MusicPlayer o-- "0..1 current" Song
SongRegistry o-- "0..*" Song
Song *-- "0..*" Instrument
Song o-- "0..*" Pattern
Pattern *-- "16" Step

TextSystem o-- "0..*" TextHandle
TextSystem --> TextMetrics
TextHandle --> TextLayer
TextSystem ..> WindowVisibility : reserves visible bands
TextSystem ..> SpaceManager : font/tile allocation

InterruptManager o-- "0..*" InterruptCallback : vblank/serial/timer
InterruptManager o-- "0..*" LcdScanlineInterrupt
LcdScanlineInterrupt o-- InterruptCallback
TimerInterrupt ..> InterruptManager : configures timer callback
SerialLink ..> InterruptManager : uses serial callbacks

@enduml
